# Rust build output
/target/

# Release bundle output
# /dist/

# Node / extension build output
/extension/node_modules/
/extension/dist/

# Per-project agent state — never commit
/.cgpt-bridge/

# Editor / OS noise
.DS_Store
*.swp
.vscode/
.idea/

# Local env / secrets
.env
.env.local
*.local

# Extension signing private key — derived public key is committed inside
# extension/manifest.json (`key` field), the private half lives only here
# and is needed only if we ever publish to the Chrome Web Store.
extension/key.pem
