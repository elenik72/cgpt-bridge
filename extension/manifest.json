{
  "manifest_version": 3,
  "name": "cgpt-bridge",
  "version": "0.0.1",
  "description": "Local personal bridge prototype for active ChatGPT tab.",
  "key": "",
  "action": {
    "default_title": "cgpt-bridge: send test prompt to active ChatGPT tab"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "activeTab", "nativeMessaging"],
  "host_permissions": ["https://chatgpt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
